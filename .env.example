# Newsletter (Resend)
RESEND_API_KEY=

# Admin panel
ADMIN_PASSWORD=
JWT_SECRET=

# Redis (auto-populated when you add a Redis store to the project)
# lib/kv.js looks for KV_URL or any env var ending in REDIS_URL
KV_URL=

# Vercel Blob (auto-populated when you add Blob to the project)
BLOB_READ_WRITE_TOKEN=

# Deploy hook (create in Vercel dashboard > Settings > Git > Deploy Hooks)
DEPLOY_HOOK_URL=
